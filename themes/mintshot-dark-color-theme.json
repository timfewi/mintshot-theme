  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "comment.block.documentation", "comment.line.documentation", "punctuation.definition.comment"],
      "settings": { "foreground": "#ededed51", "fontStyle": "italic" }
    },
    {
      "name": "Control flow keywords (purple)",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.operator.expression",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.operator.void",
        "keyword.other.rust",
        "keyword.other.crate",
        "keyword.other.use"
      ],
      "settings": { "foreground": "#4AEDC4" }
    },
    {
      "name": "Declaration keywords and storage (blue)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.type",
        "keyword.control.type",
        "keyword.other.fn",
        "keyword.declaration",
        "keyword.other"
      ],
      "settings": { "foreground": "#4AEDC4" }
    },
    {
      "name": "Catch-all keyword (purple fallback)",
      "scope": ["keyword"],
      "settings": { "foreground": "#4AEDC4" }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.type.annotation",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#bacac3" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.template", "string.quoted", "punctuation.definition.string", "string.interpolated"],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp", "constant.regexp", "regexp", "keyword.other.back-reference"],
      "settings": { "foreground": "#5ee1ff" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#d19fed" }
    },
    {
      "name": "Language constants",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined", "constant.language"],
      "settings": { "foreground": "#d19fed" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite", "entity.name.variable", "support.variable"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#91a1ff" }
    },
    {
      "name": "Properties and fields",
      "scope": ["variable.other.property", "variable.object.property", "meta.property-name", "support.variable.property", "entity.name.tag.yaml"],
      "settings": { "foreground": "#5ee1ff" }
    },
    {
      "name": "Constants and enum members",
      "scope": ["variable.other.constant", "variable.other.enummember", "constant.other", "entity.name.constant", "support.constant"],
      "settings": { "foreground": "#4FC1FF" }
    },
    {
      "name": "Types and structs",
      "scope": ["entity.name.type", "entity.name.type.class", "entity.name.struct", "support.type", "support.class"],
      "settings": { "foreground": "#afecae" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
