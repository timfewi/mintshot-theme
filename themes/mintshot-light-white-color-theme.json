  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A97A888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#5A57E5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage & Type Keywords",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.struct",
        "storage.type.type",
        "keyword.type",
        "keyword.control.new",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.other",
        "keyword.other.rust",
        "keyword.other.fn.rust",
        "keyword.other.crate.rust",
        "keyword.other.use.rust",
        "keyword.other.where.rust"
      ],
      "settings": {
        "foreground": "#5A57E5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Fallback",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#5A57E5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#617084"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#B67618"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "regexp",
        "support.other.regexp"
      ],
      "settings": {
        "foreground": "#0F8AA8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C23472"
      }
    },
    {
      "name": "Language Constants",
