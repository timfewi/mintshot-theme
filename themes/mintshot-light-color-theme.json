  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7C8C8688",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#7C52C9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage & Type Keywords",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.struct",
        "storage.type.type",
        "keyword.type",
        "keyword.control.new",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.other",
        "keyword.other.rust",
        "keyword.other.fn.rust",
        "keyword.other.crate.rust",
        "keyword.other.use.rust",
        "keyword.other.where.rust"
      ],
      "settings": {
        "foreground": "#7C52C9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Fallback",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#7C52C9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#667872"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#C76D1A"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "regexp",
        "support.other.regexp"
      ],
      "settings": {
        "foreground": "#3A8F5B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#B95C7B"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language",
        "support.constant.builtin"
      ],
      "settings": {
        "foreground": "#B95C7B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
