{
  "name": "mintshot-theme",
  "displayName": "MintShot Themes",
  "description": "A collection of dark, mint-accented themes for VS Code and compatible editors.",
  "version": "1.0.29",
  "publisher": "mintshot",
  "license": "MIT",
  "homepage": "https://github.com/timfewi/mintshot-theme#readme",
  "bugs": {
    "url": "https://github.com/timfewi/mintshot-theme/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "galleryBanner": {
    "color": "#141414",
    "theme": "dark"
  },
  "icon": "assets/mintshot-logo.png",
  "keywords": [
    "dark",
    "mint",
    "solana",
    "web3",
    "theme",
    "vscode"
  ],
  "scripts": {
    "package": "bunx @vscode/vsce package",
    "publish:vsce": "bunx @vscode/vsce publish"
  },
  "files": [
    "themes/**",
    "assets/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/timfewi/mintshot-theme.git"
  },
  "contributes": {
    "themes": [
      {
        "label": "MintShot Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-color-theme.json"
      },
      {
        "label": "MintShot Dark Blue",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-blue-color-theme.json"
      },
      {
        "label": "MintShot Dark Orange",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-orange-color-theme.json"
      },
      {
        "label": "MintShot Dark Purple",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-purple-color-theme.json"
      },
      {
        "label": "MintShot Dark Red",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-red-color-theme.json"
      },
      {
        "label": "MintShot Dark Yellow",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-yellow-color-theme.json"
      },
      {
        "label": "MintShot Dark Green",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-green-color-theme.json"
      },
      {
        "label": "MintShot Dark VS2019",
        "uiTheme": "vs-dark",
        "path": "./themes/mintshot-dark-vs2019-color-theme.json"
      }
    ]
  }
}
