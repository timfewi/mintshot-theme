  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block.documentation",
        "comment.line.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#ededed4f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.type",
        "keyword.operator.expression",
        "keyword.operator.new",
        "storage",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#4AEDC4"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#bacac3"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "punctuation.definition.string",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "regexp",
        "keyword.other.back-reference"
      ],
      "settings": {
        "foreground": "#5ee1ff"
      }
    },
    {
      "name": "Numbers and language constants",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#d19fed"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "entity.name.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "meta.parameter.object-binding",
        "meta.parameter.type.parameter"
      ],
      "settings": {
        "foreground": "#e7ffc2"
      }
    },
    {
      "name": "Properties and fields",
      "scope": [
        "variable.other.property",
        "variable.object.property",
        "meta.property-name",
        "support.variable.property",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#5ee1ff"
      }
    },
    {
      "name": "Constants and enum members",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "constant.other",
        "entity.name.constant",
        "support.constant"
      ],
